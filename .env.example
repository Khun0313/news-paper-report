# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID where daily reports will be sent
DISCORD_CHANNEL_ID=your_channel_id_here

# Schedule time (24h format, default: 07:30)
SCHEDULE_TIME=07:30

# Timezone (default: Asia/Seoul)
TIMEZONE=Asia/Seoul

# Data directory (default: ~/.config/news-paper-report)
DATA_DIR=
